# SpaceX Orbital Intelligence - Environment Configuration
# 
# ⚠️  NEVER commit this file with real values to git!
# ⚠️  Copy to .env and fill with real credentials
# 
# To get started:
#   cp backend/.env.example backend/.env
#   # Edit backend/.env with real values
#   # Make sure backend/.env has permissions 600:
#   chmod 600 backend/.env

# =============================================================================
# DATABASE CREDENTIALS
# =============================================================================

# Redis Password
# Generate secure password:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# PostgreSQL Password
# Generate secure password:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# =============================================================================
# SPACE-TRACK API CREDENTIALS
# =============================================================================
# Get your free account at: https://www.space-track.org/auth/createAccount
# If not configured, the app will use CelesTrak as fallback (slower updates)

SPACETRACK_USERNAME=your_email@example.com
SPACETRACK_PASSWORD=your_password_here

# =============================================================================
# API SECURITY
# =============================================================================

# API Key for protected endpoints
# Generate secure key:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# Leave empty to disable API key authentication (not recommended for production)
SPACEX_API_KEY=

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# Production: Only your domain
# Development: Include localhost
CORS_ORIGINS=https://spacex.ericcesar.com,http://localhost:3000,http://localhost:5173

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Environment: production, staging, development
ENV=production

# Debug mode (true/false) - NEVER enable in production!
DEBUG=false

# =============================================================================
# OPTIONAL: OBSERVABILITY
# =============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your_sentry_dsn

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# 1. NEVER commit .env to git (it's in .gitignore)
# 2. Use environment variables in production (AWS Secrets Manager, etc.)
# 3. Rotate passwords every 90 days
# 4. Use strong passwords (32+ characters, random)
# 5. Limit CORS_ORIGINS to your actual domains only
#
# Security checklist:
# - [ ] All passwords are unique and strong
# - [ ] SPACEX_API_KEY is set and secure
# - [ ] CORS_ORIGINS only includes trusted domains
# - [ ] DEBUG=false in production
# - [ ] File permissions are 600 (owner read/write only)
# - [ ] Secrets are stored in a password manager (1Password, etc.)
#
