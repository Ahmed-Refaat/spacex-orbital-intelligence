# Space-Track API Credentials
# Get your free account at: https://www.space-track.org/auth/createAccount
# If not configured, the app will use CelesTrak as fallback (slower updates)
SPACETRACK_USERNAME=your_email@example.com
SPACETRACK_PASSWORD=your_password_here

# Redis Configuration
# Strong password required for security
REDIS_PASSWORD=generate_a_strong_password_here

# PostgreSQL Configuration
# Change this in production!
POSTGRES_PASSWORD=generate_a_strong_password_here

# Security
# Optional: API key to protect endpoints (leave empty to disable)
SPACEX_API_KEY=

# CORS Origins (comma-separated)
CORS_ORIGINS=https://spacex.ericcesar.com,http://localhost:3000
